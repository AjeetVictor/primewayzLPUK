// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model FormResponse {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  phone     String?  // E.164 when provided
  createdAt DateTime @default(now())
}

model ChatSession {
  id           String                   @id @default(uuid())
  name         String?
  email        String?
  createdAt    DateTime                 @default(now())
  messages     ChatMessage[]
  attachments  ChatAttachment[]
  appointments ChatAppointmentRequest[]
}

model ChatMessage {
  id          Int              @id @default(autoincrement())
  sessionId   String
  session     ChatSession      @relation(fields: [sessionId], references: [id])
  sender      String           // 'user', 'bot', 'admin'
  text        String
  timestamp   DateTime         @default(now())
  replyToId   Int?
  replyTo     ChatMessage?     @relation("Replies", fields: [replyToId], references: [id])
  replies     ChatMessage[]    @relation("Replies")
  attachments ChatAttachment[]
}

model ChatAttachment {
  id           Int          @id @default(autoincrement())
  sessionId    String
  session      ChatSession  @relation(fields: [sessionId], references: [id])
  messageId    Int?
  message      ChatMessage? @relation(fields: [messageId], references: [id])
  url          String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  kind         String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model ChatAppointmentRequest {
  id            Int         @id @default(autoincrement())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id])
  name          String?
  email         String?
  phone         String?
  preferredDate String?
  preferredTime String?
  timezone      String?     @default("Europe/London")
  message       String?
  status        String      @default("pending") // pending/confirmed/completed/cancelled
  adminNote     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model User {
  id                     Int      @id @default(autoincrement())
  email                  String   @unique
  password               String
  role                   String   @default("viewer") // 'super_admin', 'blog_editor', 'blog_author', 'admin', 'editor', 'viewer'
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  createdAt              DateTime @default(now())
}

model CmsBlogPost {
  id             Int       @id @default(autoincrement())
  slug           String    @unique
  title          String
  description    String    @db.Text
  excerpt        String    @db.Text
  category       String
  tags           Json
  date           DateTime?
  updatedDate    DateTime?
  author         String
  readTime       String
  image          String?
  content        String    @db.LongText
  featured       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?   @db.Text
  status         String    @default("draft") // draft, submitted, published, unpublished, archived
  createdById    Int
  updatedById    Int?
  reviewedById   Int?
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BlogPostComment {
  id        Int      @id @default(autoincrement())
  postId    String
  name      String
  text      String
  createdAt DateTime @default(now())
}
