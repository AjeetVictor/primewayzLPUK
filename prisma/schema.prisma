generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Form Responses ---
model FormResponse {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  phone     String?  // nullable
  createdAt DateTime @default(now())
}

// --- Tool Leads (visibility checker, etc.) ---
model ToolLead {
  id           Int      @id @default(autoincrement())
  source       String   // e.g. "Digital Visibility Checker"
  websiteUrl   String
  score        Int?
  businessType String?
  businessName String?
  location     String?
  name         String?
  email        String?
  phone        String?
  message      String?  @db.Text
  /// Safe structured metadata for audit email-report leads (no raw report/crawler/debug data).
  details      Json?
  createdAt    DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

// --- Chat System ---
model ChatSession {
  id                String                   @id @default(uuid())
  name              String?
  email             String?
  visitorLastSeenAt DateTime?
  status            String                   @default("new") // new, bot_replied, admin_needed, admin_replied, lead_qualified, follow_up_due, booked_call, closed, spam
  firstLandingPage  String?
  currentPageUrl    String?                  @db.Text
  referrer          String?                  @db.Text
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  deviceType        String?
  browser           String?
  serviceInterest   String?
  closedAt          DateTime?
  closedById        Int?
  updatedAt         DateTime                 @updatedAt
  createdAt         DateTime                 @default(now())
  messages          ChatMessage[]
  attachments       ChatAttachment[]
  appointments      ChatAppointmentRequest[]

  @@index([status])
  @@index([createdAt])
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  sessionId      String
  session        ChatSession      @relation(fields: [sessionId], references: [id])
  sender         String           // 'user', 'bot', 'admin'
  text           String           @db.Text
  answered       Boolean          @default(false)
  isInternalNote Boolean          @default(false)
  deletedAt      DateTime?
  deletedBy      Int?
  editedAt       DateTime?
  timestamp      DateTime         @default(now())
  replyToId      Int?
  replyTo        ChatMessage?     @relation("Replies", fields: [replyToId], references: [id])
  replies        ChatMessage[]    @relation("Replies")
  attachments    ChatAttachment[]

  @@index([sessionId, timestamp])
  @@index([sender, answered])
}

model ChatAttachment {
  id           Int          @id @default(autoincrement())
  sessionId    String
  session      ChatSession  @relation(fields: [sessionId], references: [id])
  messageId    Int?
  message      ChatMessage? @relation(fields: [messageId], references: [id])
  url          String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  kind         String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model ChatAppointmentRequest {
  id            Int         @id @default(autoincrement())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id])
  name          String?
  email         String?
  phone         String?
  preferredDate String?
  preferredTime String?
  timezone      String?     @default("Europe/London")
  message       String?
  status        String      @default("pending")
  adminNote     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ChatPresenceSetting {
  id          Int      @id @default(autoincrement())
  mode        String   @default("auto") // auto / online / away / offline
  message     String?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminPresence {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  lastSeenAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- Users ---
model User {
  id                     Int      @id @default(autoincrement())
  email                  String   @unique
  password               String
  role                   String   @default("viewer")
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  createdAt              DateTime @default(now())
}

// --- CMS / Blog ---
model CmsBlogPost {
  id             Int       @id @default(autoincrement())
  slug           String    @unique
  title          String
  description    String    @db.Text
  excerpt        String    @db.Text
  category       String
  tags           Json
  date           DateTime?
  updatedDate    DateTime?
  author         String
  readTime       String
  image          String?
  content        String    @db.LongText
  featured       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?   @db.Text
  status         String    @default("draft")
  createdById    Int
  updatedById    Int?
  reviewedById   Int?
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BlogPostComment {
  id        Int      @id @default(autoincrement())
  postId    String
  name      String
  text      String
  createdAt DateTime @default(now())
}

// --- Alerts / Summary ---
model ChatAlert {
  id        Int      @id @default(autoincrement())
  sessionId String
  messageId Int
  alertType String   @default("unanswered_chat")
  status    String   @default("logged")
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([messageId, alertType])
  @@index([sessionId])
  @@index([sentAt])
}

model LeadSummaryEmail {
  id          Int       @id @default(autoincrement())
  dateKey     String
  summaryType String    @default("daily_lead_summary")
  status      String    @default("pending")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@unique([dateKey, summaryType])
  @@index([dateKey])
  @@index([status])
}
