generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Article Autopilot draft-first workflow ---
enum AutopilotQueueStatus {
  GENERATING
  READY_FOR_REVIEW
  NEEDS_ATTENTION
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum AutopilotPipelineStage {
  QUEUED
  PLANNING
  RESEARCHING
  CHECKING_OVERLAP
  BUILDING_BRIEF
  WRITING
  GENERATING_METADATA
  AUTO_REVIEWING
  SANITISING
  COMPLETED
  FAILED
}

enum AutopilotReviewVerdict {
  NOT_REVIEWED
  PASS
  PASS_WITH_WARNINGS
  FAIL
}

enum AutopilotHumanReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum AutopilotContentVersionSource {
  GENERATED
  EDITED
  REGENERATED
  IMPORTED
}

enum AutopilotContentVersionStatus {
  DRAFT
  APPROVED
  PUBLISHED
  SUPERSEDED
}

// --- Form Responses ---
model FormResponse {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  phone     String? // nullable
  createdAt DateTime @default(now())
}

// --- Tool Leads (visibility checker, etc.) ---
model ToolLead {
  id           Int      @id @default(autoincrement())
  source       String // e.g. "Digital Visibility Checker"
  websiteUrl   String
  score        Int?
  businessType String?
  businessName String?
  location     String?
  name         String?
  email        String?
  phone        String?
  message      String?  @db.Text
  /// Safe structured metadata for audit email-report leads (no raw report/crawler/debug data).
  details      Json?
  createdAt    DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

// --- Chat System ---
model ChatSession {
  id                String                   @id @default(uuid())
  name              String?
  email             String?
  visitorLastSeenAt DateTime?
  status            String                   @default("new") // new, bot_replied, admin_needed, admin_replied, lead_qualified, follow_up_due, booked_call, closed, spam
  firstLandingPage  String?
  currentPageUrl    String?                  @db.Text
  referrer          String?                  @db.Text
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  deviceType        String?
  browser           String?
  serviceInterest   String?
  closedAt          DateTime?
  closedById        Int?
  updatedAt         DateTime                 @updatedAt
  createdAt         DateTime                 @default(now())
  messages          ChatMessage[]
  attachments       ChatAttachment[]
  appointments      ChatAppointmentRequest[]

  @@index([status])
  @@index([createdAt])
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  sessionId      String
  session        ChatSession      @relation(fields: [sessionId], references: [id])
  sender         String // 'user', 'bot', 'admin'
  text           String           @db.Text
  answered       Boolean          @default(false)
  isInternalNote Boolean          @default(false)
  deletedAt      DateTime?
  deletedBy      Int?
  editedAt       DateTime?
  timestamp      DateTime         @default(now())
  replyToId      Int?
  replyTo        ChatMessage?     @relation("Replies", fields: [replyToId], references: [id])
  replies        ChatMessage[]    @relation("Replies")
  attachments    ChatAttachment[]

  @@index([sessionId, timestamp])
  @@index([sender, answered])
}

model ChatAttachment {
  id           Int          @id @default(autoincrement())
  sessionId    String
  session      ChatSession  @relation(fields: [sessionId], references: [id])
  messageId    Int?
  message      ChatMessage? @relation(fields: [messageId], references: [id])
  url          String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  kind         String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model ChatAppointmentRequest {
  id            Int         @id @default(autoincrement())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id])
  name          String?
  email         String?
  phone         String?
  preferredDate String?
  preferredTime String?
  timezone      String?     @default("Europe/London")
  message       String?
  status        String      @default("pending")
  adminNote     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ChatPresenceSetting {
  id          Int      @id @default(autoincrement())
  mode        String   @default("auto") // auto / online / away / offline
  message     String?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminPresence {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  lastSeenAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- Users ---
model User {
  id                     Int       @id @default(autoincrement())
  email                  String    @unique
  password               String
  role                   String    @default("viewer")
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  createdAt              DateTime  @default(now())

  // Article Autopilot relations (SetNull — preserve Autopilot rows if admin is removed)
  autopilotTopicsAssigned             AutopilotTopic[]              @relation("AutopilotTopicAssignedTo")
  autopilotTopicsCreated              AutopilotTopic[]              @relation("AutopilotTopicCreatedBy")
  autopilotTopicsUpdated              AutopilotTopic[]              @relation("AutopilotTopicUpdatedBy")
  autopilotTopicsDecided              AutopilotTopic[]              @relation("AutopilotTopicDecidedBy")
  autopilotActivityLogs               AutopilotActivityLog[]        @relation("AutopilotActivityLogActor")
  autopilotWorkflowRuns               AutopilotWorkflowRun[]        @relation("AutopilotWorkflowRunCreatedBy")
  autopilotSettingsUpdated            AutopilotSetting[]            @relation("AutopilotSettingUpdatedBy")
  autopilotKeywordImportBatches       AutopilotKeywordImportBatch[] @relation("AutopilotKeywordImportBatchCreatedBy")
  autopilotKeywordCandidatesReviewed  AutopilotKeywordCandidate[]   @relation("AutopilotKeywordCandidateReviewedBy")
  autopilotKeywordCandidatesConverted AutopilotKeywordCandidate[]   @relation("AutopilotKeywordCandidateConvertedBy")
  autopilotResearchSnapshotsCreated   AutopilotResearchSnapshot[]   @relation("AutopilotResearchSnapshotCreatedBy")
  autopilotResearchSnapshotsUpdated   AutopilotResearchSnapshot[]   @relation("AutopilotResearchSnapshotUpdatedBy")
  autopilotResearchSnapshotsConfirmed AutopilotResearchSnapshot[]   @relation("AutopilotResearchSnapshotConfirmedBy")
  autopilotTopicsApproved             AutopilotTopic[]              @relation("AutopilotTopicApprovedBy")
  autopilotTopicsRejected             AutopilotTopic[]              @relation("AutopilotTopicRejectedBy")
  autopilotContentVersionsCreated     AutopilotContentVersion[]     @relation("AutopilotContentVersionCreatedBy")
}

// --- CMS / Blog ---
model CmsBlogPost {
  id             Int       @id @default(autoincrement())
  slug           String    @unique
  title          String
  description    String    @db.Text
  excerpt        String    @db.Text
  category       String
  tags           Json
  date           DateTime?
  updatedDate    DateTime?
  author         String
  readTime       String
  image          String?
  content        String    @db.LongText
  featured       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?   @db.Text
  status         String    @default("draft")
  createdById    Int
  updatedById    Int?
  reviewedById   Int?
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BlogPostComment {
  id        Int      @id @default(autoincrement())
  postId    String
  name      String
  text      String
  createdAt DateTime @default(now())
}

// --- Alerts / Summary ---
model ChatAlert {
  id        Int      @id @default(autoincrement())
  sessionId String
  messageId Int
  alertType String   @default("unanswered_chat")
  status    String   @default("logged")
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([messageId, alertType])
  @@index([sessionId])
  @@index([sentAt])
}

model LeadSummaryEmail {
  id          Int       @id @default(autoincrement())
  dateKey     String
  summaryType String    @default("daily_lead_summary")
  status      String    @default("pending")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@unique([dateKey, summaryType])
  @@index([dateKey])
  @@index([status])
}

// --- Article Autopilot 2.0 (Phase 1B.2 foundation) ---
// Statuses are strings (project convention). Defaults match src/data/autopilot/status.ts.
// Secrets must remain in environment variables — AutopilotSetting is not a secrets store.

model AutopilotTopic {
  id                  Int     @id @default(autoincrement())
  workingTitle        String
  primaryKeyword      String
  supportingKeywords  Json    @default("[]")
  keywordVariants     Json    @default("[]")
  userProblem         String  @db.Text
  audience            String
  market              String  @default("United Kingdom")
  language            String  @default("en-GB")
  location            String?
  source              String  @default("manual")
  proposedSlug        String?
  primaryCategory     String?
  secondaryCategories Json    @default("[]")

  topicStatus       String @default("DISCOVERED")
  decisionStatus    String @default("NOT_READY")
  briefStatus       String @default("NOT_STARTED")
  draftStatus       String @default("NOT_STARTED")
  mediaStatus       String @default("NOT_REQUIRED")
  publishingStatus  String @default("NOT_READY")
  performanceStatus String @default("NOT_TRACKED")

  // Draft-first queue state. Legacy status fields above remain during migration.
  queueStatus      AutopilotQueueStatus       @default(GENERATING)
  pipelineStage    AutopilotPipelineStage     @default(QUEUED)
  reviewVerdict    AutopilotReviewVerdict     @default(NOT_REVIEWED)
  humanReviewStatus AutopilotHumanReviewStatus @default(PENDING)

  qualityScore      Decimal? @db.Decimal(5, 1)
  factualScore      Decimal? @db.Decimal(5, 1)
  brandVoiceScore   Decimal? @db.Decimal(5, 1)
  originalityScore  Decimal? @db.Decimal(5, 1)
  reviewIssues      Json?
  sourceEvidenceJson Json?
  autoReviewJson     Json?

  validatorNotes  String?   @db.Text
  approvedById    Int?
  approvedAt      DateTime?
  rejectedById    Int?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text

  attemptCount     Int       @default(0)
  lastError        String?   @db.Text
  lockedAt         DateTime?
  lockedBy         String?
  modelName        String?
  promptVersion    String?
  generationVersion String?
  scheduledFor     DateTime?
  publishedUrl     String?   @db.Text

  currentVersionId   Int? @unique
  approvedVersionId  Int? @unique
  publishedVersionId Int? @unique

  searchIntent           Json?
  serpEvidence           Json?
  businessAlignment      Json?
  contentArchitecture    Json?
  riskAssessment         Json?
  categoryRecommendation Json?
  scoreBreakdown         Json?
  aiMetadata             Json?

  serviceRelevance            Decimal? @db.Decimal(5, 1)
  businessValue               Decimal? @db.Decimal(5, 1)
  buyerIntent                 Decimal? @db.Decimal(5, 1)
  topicalAuthorityFit         Decimal? @db.Decimal(5, 1)
  contentGap                  Decimal? @db.Decimal(5, 1)
  differentiationPotential    Decimal? @db.Decimal(5, 1)
  rankingFeasibility          Decimal? @db.Decimal(5, 1)
  evidenceConfidence          Decimal? @db.Decimal(5, 1)
  internalLinkOpportunity     Decimal? @db.Decimal(5, 1)
  commercialPageSupport       Decimal? @db.Decimal(5, 1)
  cannibalisationPenalty      Decimal? @db.Decimal(5, 1)
  unsupportedClaimRiskPenalty Decimal? @db.Decimal(5, 1)
  rawScore                    Decimal? @db.Decimal(5, 1)
  totalScore                  Decimal? @db.Decimal(5, 1)
  scoringVersion              String?

  assignedToId      Int?
  createdById       Int?
  updatedById       Int?
  decidedById       Int?
  decidedAt         DateTime?
  decisionRationale String?   @db.Text
  mergeIntoTopicId  Int?

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  assignedTo User? @relation("AutopilotTopicAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User? @relation("AutopilotTopicCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User? @relation("AutopilotTopicUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  decidedBy  User? @relation("AutopilotTopicDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  approvedBy User? @relation("AutopilotTopicApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy User? @relation("AutopilotTopicRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)

  mergeIntoTopic   AutopilotTopic?  @relation("AutopilotTopicMerge", fields: [mergeIntoTopicId], references: [id], onDelete: SetNull)
  mergedFromTopics AutopilotTopic[] @relation("AutopilotTopicMerge")

  keywordCandidatesMatched   AutopilotKeywordCandidate[] @relation("AutopilotKeywordCandidateMatchedTopic")
  keywordCandidatesConverted AutopilotKeywordCandidate[] @relation("AutopilotKeywordCandidateConvertedTopic")
  researchSnapshots          AutopilotResearchSnapshot[]
  contentVersions            AutopilotContentVersion[] @relation("AutopilotContentVersions")
  currentVersion             AutopilotContentVersion?  @relation("AutopilotCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  approvedVersion            AutopilotContentVersion?  @relation("AutopilotApprovedVersion", fields: [approvedVersionId], references: [id], onDelete: SetNull)
  publishedVersion           AutopilotContentVersion?  @relation("AutopilotPublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)

  @@index([proposedSlug])
  @@index([topicStatus])
  @@index([decisionStatus])
  @@index([primaryCategory])
  @@index([totalScore])
  @@index([assignedToId])
  @@index([updatedAt])
  @@index([archivedAt])
  @@index([topicStatus, decisionStatus, updatedAt])
  @@index([decisionStatus, totalScore])
  @@index([mergeIntoTopicId])
  @@index([queueStatus, updatedAt])
  @@index([pipelineStage, updatedAt])
  @@index([humanReviewStatus, queueStatus, updatedAt])
  @@index([scheduledFor])
  @@index([approvedById])
  @@index([rejectedById])
}

model AutopilotActivityLog {
  id               Int      @id @default(autoincrement())
  entityType       String
  entityId         String
  eventType        String
  actorType        String
  actorId          Int?
  actorDisplayName String?
  source           String
  previousValue    Json?
  newValue         Json?
  metadata         Json?
  reason           String?  @db.Text
  correlationId    String?
  createdAt        DateTime @default(now())

  actor User? @relation("AutopilotActivityLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([eventType, createdAt])
  @@index([actorId, createdAt])
  @@index([correlationId])
  @@index([createdAt])
}

model AutopilotWorkflowRun {
  id               Int       @id @default(autoincrement())
  workflowType     String
  entityType       String
  entityId         String
  status           String    @default("queued")
  currentStep      String?
  totalSteps       Int?
  progress         Int       @default(0)
  attempt          Int       @default(1)
  startedAt        DateTime?
  completedAt      DateTime?
  errorCode        String?
  errorMessage     String?   @db.Text
  /// Provider/model/token/cost metadata only — never API keys or secrets.
  providerMetadata Json?
  inputHash        String?
  correlationId    String?
  createdById      Int?
  retryOfRunId     Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy User? @relation("AutopilotWorkflowRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  retryOf AutopilotWorkflowRun?  @relation("AutopilotWorkflowRunRetry", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries AutopilotWorkflowRun[] @relation("AutopilotWorkflowRunRetry")

  @@index([workflowType, entityType, entityId, inputHash])
  @@index([status, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([correlationId])
  @@index([retryOfRunId])
  @@index([createdById])
}

model AutopilotSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       Json
  description String?  @db.Text
  isLocked    Boolean  @default(false)
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("AutopilotSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

// --- Article Autopilot 2.0 (Phase 2A keyword imports) ---
// Statuses are strings. Source metrics are nullable and never inferred.

model AutopilotKeywordImportBatch {
  id                Int       @id @default(autoincrement())
  sourceType        String
  sourceName        String?
  originalFileName  String?
  status            String    @default("previewed")
  totalRows         Int       @default(0)
  validRows         Int       @default(0)
  invalidRows       Int       @default(0)
  duplicateRows     Int       @default(0)
  createdTopicCount Int       @default(0)
  columnMapping     Json?
  importOptions     Json?
  summary           Json?
  errorSummary      Json?
  createdById       Int?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBy  User?                       @relation("AutopilotKeywordImportBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  candidates AutopilotKeywordCandidate[]

  @@index([status])
  @@index([sourceType])
  @@index([createdById])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([sourceType, createdAt])
}

model AutopilotKeywordCandidate {
  id                     Int       @id @default(autoincrement())
  batchId                Int?
  keyword                String
  normalisedKeyword      String
  sourceRowNumber        Int?
  sourceType             String
  sourceData             Json?
  impressions            Int?
  clicks                 Int?
  ctr                    Decimal?  @db.Decimal(10, 6)
  averagePosition        Decimal?  @db.Decimal(10, 4)
  searchVolume           Int?
  keywordDifficulty      Decimal?  @db.Decimal(5, 2)
  currentUrl             String?   @db.Text
  country                String?
  language               String?
  status                 String    @default("new")
  duplicateReason        String?   @db.Text
  duplicateOfCandidateId Int?
  matchedTopicId         Int?
  convertedTopicId       Int?
  reviewNotes            String?   @db.Text
  reviewedById           Int?
  reviewedAt             DateTime?
  convertedById          Int?
  convertedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  batch          AutopilotKeywordImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  duplicateOf    AutopilotKeywordCandidate?   @relation("AutopilotKeywordCandidateDuplicate", fields: [duplicateOfCandidateId], references: [id], onDelete: SetNull)
  duplicates     AutopilotKeywordCandidate[]  @relation("AutopilotKeywordCandidateDuplicate")
  matchedTopic   AutopilotTopic?              @relation("AutopilotKeywordCandidateMatchedTopic", fields: [matchedTopicId], references: [id], onDelete: SetNull)
  convertedTopic AutopilotTopic?              @relation("AutopilotKeywordCandidateConvertedTopic", fields: [convertedTopicId], references: [id], onDelete: SetNull)
  reviewedBy     User?                        @relation("AutopilotKeywordCandidateReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  convertedBy    User?                        @relation("AutopilotKeywordCandidateConvertedBy", fields: [convertedById], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([status])
  @@index([normalisedKeyword])
  @@index([sourceType])
  @@index([convertedTopicId])
  @@index([matchedTopicId])
  @@index([duplicateOfCandidateId])
  @@index([createdAt])
  @@index([batchId, status])
  @@index([status, createdAt])
  @@index([normalisedKeyword, status])
  @@index([impressions])
  @@index([clicks])
}

// --- Article Autopilot 2.0 (Phase 2B research snapshots) ---
// Versioned, auditable research records. Confirmed snapshots are immutable.
// Deleting/archiving a topic must not cascade-delete research history (Restrict).

model AutopilotResearchSnapshot {
  id         Int    @id @default(autoincrement())
  topicId    Int
  version    Int
  status     String @default("draft")
  sourceType String @default("manual")

  query    String?
  market   String?
  language String?
  location String?

  searchIntent        Json?
  serpEvidence        Json?
  businessAlignment   Json?
  contentArchitecture Json?
  riskAssessment      Json?
  overlapAnalysis     Json?
  clusterHints        Json?
  internalLinkHints   Json?
  researchNotes       String? @db.Text

  evidenceQuality      String   @default("not_assessed")
  evidenceCompleteness Decimal? @db.Decimal(5, 1)

  createdById   Int?
  updatedById   Int?
  confirmedById Int?
  confirmedAt   DateTime?
  supersededAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  topic       AutopilotTopic @relation(fields: [topicId], references: [id], onDelete: Restrict)
  createdBy   User?          @relation("AutopilotResearchSnapshotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?          @relation("AutopilotResearchSnapshotUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  confirmedBy User?          @relation("AutopilotResearchSnapshotConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  @@unique([topicId, version])
  @@index([topicId, status, createdAt])
  @@index([status, updatedAt])
  @@index([createdById])
  @@index([confirmedById])
  @@index([confirmedAt])
}


model AutopilotContentVersion {
  id                 Int                           @id @default(autoincrement())
  topicId            Int
  version            Int
  source             AutopilotContentVersionSource @default(GENERATED)
  status             AutopilotContentVersionStatus @default(DRAFT)
  title              String
  proposedSlug       String?
  excerpt            String?                       @db.Text
  content            String                        @db.LongText
  seoTitle           String?
  seoDescription     String?                       @db.Text
  metadataJson       Json?
  schemaJson         Json?
  internalLinksJson  Json?
  sourceEvidenceJson Json?
  autoReviewJson     Json?
  changeSummary      String?                       @db.Text
  createdById        Int?
  createdAt          DateTime                      @default(now())

  topic       AutopilotTopic @relation("AutopilotContentVersions", fields: [topicId], references: [id], onDelete: Restrict)
  createdBy   User?          @relation("AutopilotContentVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  currentForTopic   AutopilotTopic? @relation("AutopilotCurrentVersion")
  approvedForTopic  AutopilotTopic? @relation("AutopilotApprovedVersion")
  publishedForTopic AutopilotTopic? @relation("AutopilotPublishedVersion")

  @@unique([topicId, version])
  @@index([topicId, status, createdAt])
  @@index([createdById])
}
