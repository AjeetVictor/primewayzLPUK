{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "npm run images:optimize && node scripts/validate-base-path.mjs",
    "build": "npm run build:client && npm run build:ssr",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "lint:native-dialogs": "node scripts/check-no-native-dialogs.mjs",
    "test": "tsx --test src/lib/audit/report/buildRecommendedFocus.test.ts src/lib/audit/report/recommendationActions.test.ts",
    "start": "tsx scripts/start-server.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "data:migrate:sqlite-to-mysql": "node scripts/migrate-sqlite-to-mysql.mjs",
    "build:client": "vite build --outDir dist/client",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "images:optimize": "node scripts/convert-images-to-webp.mjs",
    "validate:bing": "node scripts/validate-bing-verification.mjs",
    "validate:indexnow-key": "node scripts/validate-indexnow-key.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@types/nodemailer": "8.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "6.0.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "1.12.41",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "mysql2": "^3.20.0",
    "nodemailer": "8.0.10",
    "path": "^0.12.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-phone-number-input": "3.4.16",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "prisma": "^6.19.2",
    "sharp": "0.35.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-svgr": "5.2.0"
  }
}
