# ------------------------------------------------------------
# Primewayz UK Landing Page Environment Template
# Copy this file to .env for production or local development.
# Never commit real .env files or real secrets.
# ------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000

# App base path
APP_BASE_PATH=/
VITE_APP_BASE_PATH=/

# Database
# Production example:
# DATABASE_URL="mysql://DB_USER:DB_PASSWORD@127.0.0.1:3306/primewayz-lpageuk"
#
# Local example:
# DATABASE_URL="mysql://root:YOUR_LOCAL_PASSWORD@127.0.0.1:3306/primewayz-lpageuk"
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/primewayz-lpageuk"

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=primewayz-lpageuk

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Auth / JWT
JWT_ACCESS_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_min_32_chars
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL_DAYS=7

# Cookies
# Use false for local HTTP.
# Use true for production HTTPS.
COOKIE_SECURE=false

# CORS
# Local:
# CORS_ORIGIN="http://localhost:3000"
#
# Production:
# CORS_ORIGIN="https://uk.primewayz.com,http://localhost:3000,https://kreatorbox.com"
CORS_ORIGIN="http://localhost:3000"

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_RECEIVER_EMAIL=

# Server-side chat provider, OpenAI-compatible endpoint
CHAT_API_KEY=
CHAT_API_BASE=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini


# Google Analytics 4
VITE_GA_MEASUREMENT_ID=

# ------------------------------------------------------------
# Article Autopilot — Google Search Console (Phase 2A)
# Leave blank until Google Cloud OAuth credentials are configured.
# Missing values do not prevent the app from starting; GSC admin
# endpoints return CONFIGURATION_REQUIRED until set.
# ------------------------------------------------------------
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/admin/autopilot/gsc/oauth/callback

# Base64-encoded 32-byte key for AES-256-GCM refresh-token encryption.
# Generate locally, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Do not commit real keys. Malformed or wrong-length keys are rejected (never auto-generated).
AUTOPILOT_GSC_TOKEN_ENCRYPTION_KEY=

# HMAC-SHA256 secret for OAuth state signing (minimum 32 characters).
# Do not commit real secrets. Missing/short secrets are rejected (never auto-generated).
AUTOPILOT_GSC_OAUTH_STATE_SECRET=

# Sync window defaults (Search Console final data; Pacific calendar dates)
AUTOPILOT_GSC_DEFAULT_LOOKBACK_DAYS=28
AUTOPILOT_GSC_DATA_DELAY_DAYS=3

# Local dev convenience: set true to skip loading the chat widget entirely
# VITE_DISABLE_CHAT=true
